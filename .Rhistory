Age_w2 = "Age", Procrastination_total = "Procrastination", Depression_total = "Depression",
Loneliness_total = "Loneliness", Education = "Education", Job_status = "Retired (Yes/No)",
Marital_status = "Married (Yes/No)"
)
stat <- list(
