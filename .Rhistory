lon_w2 ~ a2*Age_w2;
# Indirect effect
DIDE := a1*b1;
LIDE := a2*b2;
Total_Indirect_Effect := (a1*b1) + (a2*b2)
# Total Effect
Total_Effect := c + (a1*b1) + (a2*b2)
'
