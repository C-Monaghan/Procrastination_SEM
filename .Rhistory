dep_w2 ~ a1*Age_w2;
Health_assessment ~ a2*Age_w2;
# INDIRECT EFFECT
DIDE := a1*b1;
HIDE := a2*b2;
Total_IE := (a1*b1) + (a2*b2)
# TOTAL EFFECT
Total_Effect := c + (a1*b1) + (a2*b2)
'
